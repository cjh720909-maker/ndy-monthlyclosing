generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LongDistance {
  id               Int                   @id @default(autoincrement())
  driverName       String
  vehicleNo        String
  tonnage          String?
  region           String?
  currentAllowance Int                   @default(0)
  note             String?
  isActive         Boolean               @default(true)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  history          LongDistanceHistory[]

  @@map("NMC_LongDistance")
}

model LongDistanceHistory {
  id        Int          @id @default(autoincrement())
  vehicleId Int
  year      String
  applyDate DateTime
  amount    Int
  reason    String?
  createdAt DateTime     @default(now())
  vehicle   LongDistance @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("NMC_LongDistanceHistory")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  fullName  String?
  role      String   @default("USER")
  canAccess Boolean  @default(true)
  canRead   Boolean  @default(true)
  canWrite  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("NMC_User")
}

model AdditionalCost {
  id           Int      @id @default(autoincrement())
  year         String
  name         String
  type         String
  contractType String
  baseRate     Int      @default(0)
  allowance    Int      @default(0)
  workingHours Float    @default(9)
  note         String?
  createdAt    DateTime @default(now())

  @@map("NMC_AdditionalCost")
}

model MonthlyVehicleCost {
  id          Int      @id @default(autoincrement())
  year        String
  workingDays String   @default("6")
  cost1T      Int      @default(0)
  cost2T      Int      @default(0)
  cost2_5T    Int      @default(0)
  cost3T      Int      @default(0)
  cost3_5T    Int      @default(0)
  cost5T      Int      @default(0)
  cost5TAxis  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([year, workingDays])
  @@map("NMC_MonthlyVehicleCost")
}

model NDY_BillingItem {
  id               String            @id
  code             String            @default("")
  name             String
  billingRecipient String            @default("")
  type             String            @default("기본운임")
  mergeCriteria    String            @default("name")
  note             String            @default("")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime
  NDY_BillingRate  NDY_BillingRate[]

  @@map("NMC_BillingItem")
}

model NDY_BillingRate {
  id              String          @id
  itemId          String
  validFrom       String
  validTo         String?
  amount          Int             @default(0)
  note            String          @default("")
  createdAt       DateTime        @default(now())
  NDY_BillingItem NDY_BillingItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("NMC_BillingRate")
}

model NDY_Config {
  key       String   @id
  data      Json
  updatedAt DateTime

  @@map("NMC_Config")
}

model NDY_DailySummary {
  id                   String                 @id
  startDate            String
  endDate              String
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  NDY_DailySummaryItem NDY_DailySummaryItem[]

  @@unique([startDate, endDate])
  @@map("NMC_DailySummary")
}

model NDY_DailySummaryItem {
  id               String           @id
  summaryId        String
  placeName        String
  deliveryDays     Int              @default(0)
  totalAmount      Int              @default(0)
  deliveryDates    String[]
  NDY_DailySummary NDY_DailySummary @relation(fields: [summaryId], references: [id], onDelete: Cascade)

  @@map("NMC_DailySummaryItem")
}

model NDY_EmergencyRate {
  name      String   @id
  rate      Int      @default(0)
  chung     String   @default("")
  updatedAt DateTime

  @@map("NMC_EmergencyRate")
}

model NDY_EmergencySettlement {
  id        String   @id
  startDate String
  endDate   String
  name      String
  chung     String   @default("")
  count     Int      @default(0)
  rate      Int      @default(0)
  total     Int      @default(0)
  dates     String[]
  createdAt DateTime @default(now())

  @@unique([startDate, endDate, name])
  @@map("NMC_EmergencySettlement")
}

model NDY_FixedSettlement {
  id               String   @id
  name             String
  billingRecipient String   @default("")
  amount           Int      @default(0)
  count            Int      @default(0)
  rate             Int      @default(0)
  note             String?
  createdAt        DateTime @default(now())

  @@map("NMC_FixedSettlement")
}

model NDY_GSSettlement {
  id      String   @id
  date    String
  code    String
  name    String?
  qty     Decimal  @db.Decimal(11, 2)
  weight  Decimal  @db.Decimal(11, 2)
  amount  Int      @default(0)
  remarks String?  @default("")
  modDate DateTime @default(now())

  @@unique([date, code])
  @@map("NMC_GSSettlement")
}

model NDY_GSSummary {
  id          String   @id
  startDate   String
  endDate     String
  weekday     Int      @default(0)
  saturday    Int      @default(0)
  sunday      Int      @default(0)
  extraTrucks Int      @default(0)
  totalAmount Int      @default(0)
  dates       String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@unique([startDate, endDate])
  @@map("NMC_GSSummary")
}

model NDY_InquirySettlement {
  id        String   @id
  startDate String
  endDate   String
  date      String
  name      String
  so        String
  nap       String
  ton       String
  kum       Int      @default(0)
  yo        String
  chung     String
  un        Int      @default(0)
  memo      String
  createdAt DateTime @default(now())

  @@unique([startDate, endDate, date, name, so, nap, kum])
  @@map("NMC_InquirySettlement")
}

model NDY_MonthlyClosing {
  id        String   @id
  startDate String
  endDate   String
  data      Json
  closedAt  DateTime @default(now())

  @@unique([startDate, endDate])
  @@map("NMC_MonthlyClosing")
}

model NMC_Turn2RateHistory {
  id               Int              @id @default(autoincrement())
  vehicleId        Int
  applyDate        DateTime
  dailyRate        Int              @default(0)
  monthlyRate      Int              @default(0)
  note             String?
  createdAt        DateTime         @default(now())
  NMC_Turn2Vehicle NMC_Turn2Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model NMC_Turn2Vehicle {
  id                   Int                    @id @default(autoincrement())
  driverName           String
  vehicleNo            String?
  phone                String?
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  NMC_Turn2RateHistory NMC_Turn2RateHistory[]
}
model NMC_AbsenceTreatment {
  id            Int      @id @default(autoincrement())
  date          String
  driverName    String
  vehicleNumber String
  isTreated     Boolean  @default(false)
  remarks       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([date, driverName, vehicleNumber])
  @@map("NMC_AbsenceTreatment")
}
